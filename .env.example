# Copy this file to .env and fill in your values
# cp .env.example .env

# MQTT broker host (IP or hostname)
MQTT_HOST=localhost

# MQTT broker port (default 1883)
MQTT_PORT=1883

# MQTT credentials
MQTT_USER=esp32
MQTT_PASS=your_password_here

# SQLite database path (relative or absolute)
DB_PATH=./bms.db

# How many days of history to keep
KEEP_DAYS=30
